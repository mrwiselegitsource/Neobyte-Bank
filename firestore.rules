rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global utility validators
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthAdmin() {
      return isSignedIn()
        && request.auth.token.email.toLowerCase().startsWith('bankadmin')
        && request.auth.token.email.toLowerCase().endsWith('admin.com');
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Strict validation blueprint for a PrepaidCard payload
    function isValidCard(data) {
      return data.id is string && data.id.size() <= 128
        && data.brand is string && (data.brand == 'Mastercard' || data.brand == 'Visa' || data.brand == 'Amex' || data.brand == 'Discover' || data.brand == 'Atmos')
        && data.name is string && data.name.size() <= 128
        && data.price is number && data.price > 0
        && data.limit is number && data.limit >= 100
        && data.cardNumber is string && data.cardNumber.size() <= 64
        && data.expiry is string && data.expiry.size() <= 16
        && data.cvv is string && data.cvv.size() <= 16
        && data.accountHolder is string && data.accountHolder.size() <= 128
        && data.address is string && data.address.size() <= 256
        && data.country is string && data.country.size() <= 128
        && (data.imageURL == null || (data.imageURL is string && data.imageURL.size() <= 1024));
    }

    // Strict validation for UserAccount document
    function isValidUserAccount(data) {
      return data.email is string && data.email.size() <= 128
        && data.username is string && data.username.size() <= 64
        && (data.firstName == null || (data.firstName is string && data.firstName.size() <= 128))
        && (data.lastName == null || (data.lastName is string && data.lastName.size() <= 128));
    }

    // Strict validation for PurchasedCard document
    function isValidPurchasedCard(data) {
      return data.id is string && data.id.size() <= 128
        && data.brand is string && (data.brand == 'Mastercard' || data.brand == 'Visa' || data.brand == 'Amex' || data.brand == 'Discover' || data.brand == 'Atmos')
        && data.name is string && data.name.size() <= 128
        && data.price is number && data.price >= 0
        && data.limit is number && data.limit >= 0
        && data.cardNumber is string && data.cardNumber.size() <= 64
        && data.expiry is string && data.expiry.size() <= 16
        && data.cvv is string && data.cvv.size() <= 16
        && data.accountHolder is string && data.accountHolder.size() <= 128
        && data.purchaseDate is string && data.purchaseDate.size() <= 32
        && data.isFrozen is bool
        && data.ownerId is string && data.ownerId.size() <= 128
        && (data.notes == null || (data.notes is string && data.notes.size() <= 1024));
    }

    // Cards item collection rules
    match /cards/{cardId} {
      allow read: if true;
      allow create, update: if isAuthAdmin() && isValidId(cardId) && isValidCard(incoming());
      allow delete: if isAuthAdmin() && isValidId(cardId);
    }

    // Analytics (visitor counters) rules
    match /analytics/{analyticsId} {
      allow read: if true;
      allow create: if isValidId(analyticsId) && incoming().count is number;
      allow update: if isValidId(analyticsId) && incoming().count is number;
      allow delete: if false;
    }

    // User profile mapping data rules
    match /users/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create, update: if isValidId(userId) && isSignedIn() && userId == request.auth.uid && isValidUserAccount(incoming());
      allow delete: if false;
    }

    // Purchased cards durable collection rules
    match /purchasedCards/{purchaseId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isValidId(purchaseId) && isSignedIn() && incoming().ownerId == request.auth.uid && isValidPurchasedCard(incoming());
      allow update: if isValidId(purchaseId) && isSignedIn() && existing().ownerId == request.auth.uid && incoming().ownerId == request.auth.uid && isValidPurchasedCard(incoming());
      allow delete: if isValidId(purchaseId) && isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
